{
  "name": "ai-fifa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @ai-fifa/api --filter @ai-fifa/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist .wrangler node_modules/.cache"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd", "wrangler", "@cloudflare/vitest-pool-workers"]
  }
}
